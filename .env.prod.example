# Скопируйте этот файл в .env.prod и заполните значения
# cp .env.prod.example .env.prod

# База данных
POSTGRES_DB=quality_monitor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=СИЛЬНЫЙ_ПАРОЛЬ_БД

# JWT (обязательно замените на длинную случайную строку!)
SECRET_KEY=замените-на-длинную-случайную-строку-минимум-32-символа
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30
